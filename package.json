{
  "name": "@nimir/dot-path",
  "version": "3.0.0",
  "description": "Dot path resolver for typescript",
  "keywords": [
    "Typescript",
    "dottedpath",
    "dotpath",
    "vite",
    "vitest",
    "dot syntax",
    "get",
    "set",
    "deep",
    "nesting",
    "update",
    "change",
    "typesafe"
  ],
  "homepage": "https://www.github.com/Mimikkk/dot-path",
  "bugs": {
    "url": "https://github.com/Mimikkk/dot-path/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mimikkk/dot-path.git"
  },
  "license": "MIT",
  "author": "Daniel Zdancewicz <zdancewicz.daniel@gmail.com>",
  "type": "module",
  "exports": {
    "types": "./build/dot-path.d.ts",
    "require": "./build/dot-path.cjs.js",
    "default": "./build/dot-path.es.js"
  },
  "main": "./build/dot-path.cjs.js",
  "unpkg": "./build/dot-path.umd.js",
  "module": "./build/dot-path.es.js",
  "source": "./src/dot-path.ts",
  "files": [
    "build",
    "src/",
    "tsconfig.json",
    "tsconfig.vite.json",
    "vite.config.ts"
  ],
  "scripts": {
    "build": "pnpm run build:clear && concurrently -n build: 'pnpm:build:*' -c=cyan.bold,green.bold,blue.bold",
    "build:clear": "rimraf build",
    "build:lib": "vite build",
    "build:tsc": "tsc --project tsconfig.library.json",
    "test": "vitest test",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
